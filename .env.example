# heyvoca_admin 환경 변수 템플릿
# 실제 파일: .env.dev / .env.stg / .env (prod). gitignore.

SECRET_KEY=change-me

# DB (heyvoca admin 테이블이 있는 schema)
DB_USER=voca
DB_PASSWORD=voca!@34
DB_HOST=mysql
DB_PORT=3306
DB_NAME=heyvoca

# 백엔드 (같은 docker network의 컨테이너 이름)
BACKEND_URL=http://back:5000

# 백엔드 /admin/* 인증 (양쪽 같은 값)
ADMIN_API_KEY=change-me

# 선택
OPENAI_API_KEY=
GEMINI_API_KEY=
ANTHROPIC_API_KEY=
